# Copy this file to .env.local and fill in the value.
#   cp .env.example .env.local
#
# Web3Forms access key for the booking / quote form.
#
# Where to get one:
#   1. Go to https://web3forms.com
#   2. Enter the inbox that should receive submissions (hello@bunabet.com)
#   3. They email you an access key. Paste it below.
# No account or password required.
#
# Despite the name, this holds an access KEY, not a URL. The POST target is a
# constant in components/BookingForm.tsx. The variable is named this way to
# match the project spec.
#
# NEXT_PUBLIC_ means this is exposed to the browser. That is correct and
# expected for Web3Forms: the key is a submission token, not a secret.
#
# For deploys, add the same variable in Vercel under
# Settings > Environment Variables.
NEXT_PUBLIC_FORM_ENDPOINT=
